# =============================================================================
# VAPTANIX Instagram Auto-Poster - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED - Instagram/Meta API Setup
# =============================================================================

# Your Instagram Business Account ID (starts with 178...)
# Get from: Graph API Explorer or Meta Business Suite
INSTAGRAM_USER_ID=your_instagram_account_id_here

# Meta/Facebook Access Token
# Generate at: https://developers.facebook.com/tools/explorer/
# IMPORTANT: Extend the token after generating!
ACCESS_TOKEN=your_facebook_access_token_here

# Facebook Page ID (if applicable)
# Get from: me/accounts in Graph API Explorer
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# =============================================================================
# OPTIONAL - Image Sources
# =============================================================================

# Image source: "unsplash" or "ai"
IMAGE_SOURCE=unsplash

# Unsplash API Key (for free stock photos)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# =============================================================================
# CONFIGURATION
# =============================================================================

# Content niche for captions (cybersecurity, food, travel, etc.)
NICHE=cybersecurity

# Posting times (24-hour format, comma-separated)
# Default: 07:00,09:00,12:00,15:00,18:00,21:00
POSTING_TIMES=07:00,09:00,12:00,15:00,18:00,21:00

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=60

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Use AI-generated images (FREE via Pollinations.ai)
# Set to "true" to enable AI images
USE_AI_IMAGES=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 
# 1. Get INSTAGRAM_USER_ID:
#    - Go to https://developers.facebook.com/tools/explorer/
#    - Generate token with permissions: instagram_basic, instagram_content_publish, pages_read_engagement
#    - Query: {page-id}?fields=instagram_business_account
#    - Copy the instagram_business_account id
#
# 2. Get ACCESS_TOKEN:
#    - Same as above, extend the token (click 'i' then 'Extend')
#    - Copy the extended token
#
# 3. Get UNSPLASH_ACCESS_KEY (optional):
#    - Go to https://unsplash.com/developers
#    - Register as developer, create app
#    - Copy the Access Key
#
# 4. Add to GitHub Secrets:
#    - Repository Settings → Secrets and variables → Actions
#    - Add each secret with the actual values
#
# =============================================================================
